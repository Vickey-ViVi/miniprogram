.home-page {
  min-height: 100vh;
  padding: 0 32rpx 48rpx;
  background: linear-gradient(180deg, #1e2a3a 0%, #1e2a3a 320rpx, #f5f7fa 320rpx);
}

.hero {
  padding: 60rpx 16rpx 48rpx;
  color: #ffffff;
}

.hero-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: rgba(201, 169, 110, 0.25);
  border: 1rpx solid rgba(201, 169, 110, 0.5);
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #e8d5a8;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
}

.feature-list {
  margin-top: 56rpx;
}

.feature-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(30, 42, 58, 0.08);
  transition: transform 0.15s;
}

.feature-card:active {
  transform: scale(0.98);
}

.feature-card.smart {
  border-left: 8rpx solid #07c160;
}

.feature-card.complaint {
  border-left: 8rpx solid #f5576c;
}

.feature-card.propose {
  border-left: 8rpx solid #c9a96e;
}

.feature-icon {
  font-size: 52rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.feature-body {
  flex: 1;
}

.feature-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1e2a3a;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #888888;
  line-height: 1.5;
}

.feature-arrow {
  font-size: 48rpx;
  color: #cccccc;
  font-weight: 300;
  margin-left: 16rpx;
}

.footer-tip {
  text-align: center;
  font-size: 22rpx;
  color: #bbbbbb;
  margin-top: 40rpx;
}
