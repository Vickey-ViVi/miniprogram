.chat-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f7fa;
}

.message-list {
  flex: 1;
  padding: 20rpx 20rpx 140rpx;
  overflow-y: auto;
}

.message-item {
  display: flex;
  margin-bottom: 30rpx;
  width: 100%;
}

.message-item.user {
  justify-content: flex-end;
}
.message-item.bot {
  justify-content: flex-start;
}

.bubble {
  max-width: 80%;
  padding: 24rpx 32rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-wrap: break-word;      /* 允许长单词换行 */
  white-space: pre-wrap;      /* 保留空格和换行 */
  overflow-wrap: break-word;  /* 增强兼容性 */
  box-sizing: border-box;
}

/* 用户气泡*/
.message-item.user .bubble {
  background-color: #07c160;
  color: #ffffff;
  margin-right: 35rpx;
}

/* 机器人气泡*/
.message-item.bot .bubble {
  background-color: #ffffff;
  color: #333333;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 选项区域 */
.options-area {
  padding: 20rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #e8e8e8;
}

.options-title {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 20rpx;
  text-align: center;
}

.options-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
}

.option-btn {
  padding: 20rpx 40rpx;
  background-color: #f5f7fa;
  border: 1rpx solid #e0e0e0;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #333333;
  margin: 0;
  white-space: nowrap;        
  flex-shrink: 0;
}
.option-btn:active {
  background-color: #e8f5e9;
  color: #07c160;
  border-color: #07c160;
}

/* 输入区域 */
.input-area {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #e8e8e8;
  gap: 16rpx;
}

.input-box {
  flex: 1;
  height: 80rpx;
  padding: 0 32rpx;
  background-color: #f5f7fa;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 120rpx;
  height: 80rpx;
  background-color: #07c160;
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  margin: 0;
}
.send-btn:active {
  background-color: #06ad56;
}

#bottom {
  height: 20rpx;
}

.toolbar {
  padding: 12rpx 20rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #e8e8e8;
  display: flex;
  justify-content: center;
}

.reset-type-btn {
  margin: 0;
  padding: 0 32rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  color: #666666;
  background-color: #f5f7fa;
  border: 1rpx solid #e0e0e0;
  border-radius: 32rpx;
  white-space: nowrap;
  width: auto;
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
}

.reset-type-btn::after {
  border: none;
}

.reset-type-btn:active {
  color: #07c160;
  border-color: #07c160;
  background-color: #e8f5e9;
}

.recommend-bar {
  padding: 16rpx 20rpx 24rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #e8e8e8;
}

.recommend-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #1e2a3a, #2d4059);
  color: #c9a96e;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin: 0;
}