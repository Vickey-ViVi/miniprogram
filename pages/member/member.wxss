.member-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 48rpx;
}

.profile-header {
  background: linear-gradient(135deg, #1e2a3a 0%, #2d4a6e 100%);
  padding: 60rpx 32rpx 48rpx;
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-right: 28rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.profile-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.quick-menu {
  display: flex;
  background: #ffffff;
  margin: -32rpx 32rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(30, 42, 58, 0.1);
}

.menu-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.menu-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.menu-text {
  font-size: 22rpx;
  color: #666666;
}

.history-section {
  margin: 0 32rpx 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(30, 42, 58, 0.08);
}

.history-tabs {
  display: flex;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 28rpx;
  color: #888888;
}

.history-tab.active {
  color: #1e2a3a;
  font-weight: 600;
  border-bottom: 4rpx solid #c9a96e;
}

.history-card {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.history-card:last-child {
  border-bottom: none;
}

.history-time {
  font-size: 22rpx;
  color: #bbbbbb;
  margin-bottom: 8rpx;
}

.history-type {
  font-size: 26rpx;
  color: #c9a96e;
  margin-bottom: 4rpx;
}

.history-content {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}

.about-section {
  margin: 0 32rpx;
  text-align: center;
  padding: 32rpx;
}

.about-title {
  font-size: 26rpx;
  color: #888888;
  margin-bottom: 8rpx;
}

.about-text {
  font-size: 24rpx;
  color: #bbbbbb;
  margin-bottom: 8rpx;
}

.about-version {
  font-size: 22rpx;
  color: #cccccc;
}
